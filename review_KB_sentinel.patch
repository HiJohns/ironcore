+class KBIngestProcessor:
+    """Knowledge Base Ingestion Processor"""
+    
+    def __init__(self):
+        self.db_path = DB_PATH
+        self.llm_scorer = LLMScorer()
+    
+    def process_kb_ingest(self, item_id: str, content: str, content_type: str) -> dict:
+        """
+        Process knowledge base ingestion request
+        
+        Args:
+            item_id: UUID for the knowledge item
+            content: The content to process (URL or raw text)
+            content_type: 'url' or 'raw_text'
+        
+        Returns:
+            dict: Processing result with title, tags, tldr, impact_score
+        """
+        logger.info(f"[KB] Processing ingest for item {item_id}, type: {content_type}")
+        
+        try:
+            # Fetch content if URL
+            if content_type == 'url':
+                text_content, metadata = self.fetch_url_content(content)
+                original_url = content
+            else:
+                text_content = content
+                original_url = None
+                metadata = {}
+            
+            # Process with LLM
+            result = self.process_with_llm(text_content, metadata)
+            
+            # Save to database
+            self.save_to_db(item_id, result, text_content, original_url)
+            
+            logger.info(f"[KB] Successfully processed item {item_id}: {result.get('title', 'Unknown')}")
+            return result
+            
+        except Exception as e:
+            logger.error(f"[KB] Failed to process ingest for item {item_id}: {e}")
+            raise
+    
+    def fetch_url_content(self, url: str) -> tuple:
+        """
+        Fetch and extract content from URL
+        Returns: (text_content, metadata)
+        """
+        try:
+            import requests
+            from urllib.parse import urlparse
+            
+            headers = {
+                'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
+            }
+            
+            response = requests.get(url, headers=headers, timeout=30)
+            response.raise_for_status()
+            
+            # Try to extract readable content
+            try:
+                from bs4 import BeautifulSoup
+                soup = BeautifulSoup(response.text, 'html.parser')
+                
+                # Remove script and style elements
+                for script in soup(["script", "style", "nav", "header", "footer"]):
+                    script.decompose()
+                
+                # Get title
+                title = soup.title.string if soup.title else ''
+                
+                # Get main content
+                text = soup.get_text(separator='\n', strip=True)
+                
+                # Clean up whitespace
+                lines = (line.strip() for line in text.splitlines())
+                chunks = (phrase.strip() for line in lines for phrase in line.split("  "))
+                text = '\n'.join(chunk for chunk in chunks if chunk)
+                
+                metadata = {
+                    'title': title,
+                    'url': url,
+                    'domain': urlparse(url).netloc
+                }
+                
+                return text[:10000], metadata  # Limit content length
+                
+            except ImportError:
+                # Fallback to plain text
+                return response.text[:10000], {'url': url}
+                
+        except Exception as e:
+            logger.error(f"[KB] Failed to fetch URL {url}: {e}")
+            raise
+    
+    def process_with_llm(self, content: str, metadata: dict) -> dict:
+        """
+        Process content with LLM to extract structured data
+        Returns: dict with title, tags, tldr, impact_score
+        """
+        # Truncate content if too long
+        max_length = 8000
+        if len(content) > max_length:
+            content = content[:max_length] + "..."
+        
+        prompt = f"""Analyze this content and extract structured information for a knowledge base.
+
+Content:
+{content}
+
+Please return a JSON object with the following fields:
+{{
+    "title": "A concise, descriptive title (max 100 chars)",
+    "tags": ["relevant", "tags", "based", "on", "content", "3-5", "tags"],
+    "tldr": "A 1-2 sentence summary of the key points (max 200 chars)",
+    "impact_score": 0.75  // A score from 0.0 to 1.0 indicating relevance to infrastructure/energy/investment themes
+}}
+
+Guidelines for impact_score:
+- 0.9-1.0: Directly related to power grid, transformers, energy infrastructure, or major policy changes
+- 0.7-0.9: Related to technology, AI infrastructure, supply chain
+- 0.4-0.7: Related to macro trends, market movements
+- 0.0-0.4: General knowledge, peripheral topics
+
+Return ONLY the JSON object, no markdown formatting or additional text."""
+
+        try:
+            # Use Gemini/OpenAI for processing
+            import openai
+            
+            api_key = os.environ.get('LLM_API_KEY')
+            api_base = os.environ.get('LLM_API_BASE', 'https://api.openai.com/v1')
+            
+            if not api_key:
+                logger.warning("[KB] LLM_API_KEY not set, using heuristic processing")
+                return self._heuristic_process(content, metadata)
+            
+            client = openai.OpenAI(api_key=api_key, base_url=api_base)
+            
+            response = client.chat.completions.create(
+                model="gpt-3.5-turbo",
+                messages=[
+                    {"role": "system", "content": "You are a knowledge extraction assistant. Always return valid JSON."},
+                    {"role": "user", "content": prompt}
+                ],
+                temperature=0.3,
+                max_tokens=500
+            )
+            
+            result_text = response.choices[0].message.content.strip()
+            
+            # Clean up JSON if wrapped in markdown
+            if result_text.startswith('```json'):
+                result_text = result_text[7:]
+            if result_text.startswith('```'):
+                result_text = result_text[3:]
+            if result_text.endswith('```'):
+                result_text = result_text[:-3]
+            
+            result = json.loads(result_text.strip())
+            
+            # Validate and set defaults
+            result.setdefault('title', metadata.get('title', 'Untitled'))
+            result.setdefault('tags', [])
+            result.setdefault('tldr', '')
+            result.setdefault('impact_score', 0.5)
+            
+            # Ensure impact_score is within bounds
+            result['impact_score'] = max(0.0, min(1.0, float(result['impact_score'])))
+            
+            return result
+            
+        except Exception as e:
+            logger.error(f"[KB] LLM processing failed: {e}, falling back to heuristic")
+            return self._heuristic_process(content, metadata)
+    
+    def _heuristic_process(self, content: str, metadata: dict) -> dict:
+        """Fallback heuristic processing when LLM is unavailable"""
+        content_lower = content.lower()
+        
+        # Extract title from first line or metadata
+        lines = content.strip().split('\n')
+        title = metadata.get('title', '')
+        if not title and lines:
+            title = lines[0][:100]
+        if not title:
+            title = "Untitled Knowledge Item"
+        
+        # Generate tags based on keywords
+        keywords = {
+            'power-grid': ['power grid', 'transformer', 'electricity', 'grid', 'voltage'],
+            'energy': ['energy', 'renewable', 'solar', 'wind', 'nuclear'],
+            'ai': ['ai', 'artificial intelligence', 'machine learning', 'llm', 'model'],
+            'infrastructure': ['infrastructure', 'construction', 'project', 'investment'],
+            'policy': ['policy', 'regulation', 'government', 'subsidy', 'tariff'],
+            'supply-chain': ['supply chain', 'shortage', 'production', 'manufacturing']
+        }
+        
+        tags = []
+        for tag, keywords_list in keywords.items():
+            if any(kw in content_lower for kw in keywords_list):
+                tags.append(tag)
+        
+        if not tags:
+            tags = ['general']
+        
+        # Generate TLDR from first few sentences
+        tldr = ' '.join(lines[:2])[:200]
+        if len(tldr) > 197:
+            tldr = tldr[:197] + '...'
+        
+        # Calculate impact score based on keyword density
+        impact_keywords = ['transformer', 'power grid', 'energy', 'infrastructure', 'investment']
+        score = 0.3  # Base score
+        for kw in impact_keywords:
+            if kw in content_lower:
+                score += 0.1
+        score = min(1.0, score)
+        
+        return {
+            'title': title,
+            'tags': tags[:5],
+            'tldr': tldr,
+            'impact_score': score
+        }
+    
+    def save_to_db(self, item_id: str, result: dict, content: str, original_url: str = None):
+        """Save processed knowledge to database"""
+        import sqlite3
+        from datetime import datetime
+        
+        conn = sqlite3.connect(self.db_path)
+        cursor = conn.cursor()
+        
+        now = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
+        
+        try:
+            # Insert kb_item
+            cursor.execute('''
+                INSERT INTO kb_items (id, title, content, tldr, original_url, impact_score, created_at, updated_at)
+                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
+            ''', (
+                item_id,
+                result['title'],
+                content,
+                result.get('tldr', ''),
+                original_url,
+                result['impact_score'],
+                now,
+                now
+            ))
+            
+            # Process tags
+            for tag_name in result.get('tags', []):
+                # Insert or get tag
+                cursor.execute('INSERT OR IGNORE INTO tags (name) VALUES (?)', (tag_name.lower(),))
+                cursor.execute('SELECT id FROM tags WHERE name = ?', (tag_name.lower(),))
+                tag_id = cursor.fetchone()[0]
+                
+                # Link tag to item
+                cursor.execute(
+                    'INSERT OR IGNORE INTO item_tags (item_id, tag_id) VALUES (?, ?)',
+                    (item_id, tag_id)
+                )
+            
+            conn.commit()
+            
+            # Log the ingestion
+            logger.info(f'[KB] New Knowledge Ingested: "{result["title"]}", Impact: {result["impact_score"]:.2f}')
+            
+        except Exception as e:
+            conn.rollback()
+            logger.error(f"[KB] Failed to save to database: {e}")
+            raise
+        finally:
+            conn.close()
+
+
+def process_kb_ingest_command():
+    """Handle KB ingest command line invocation"""
+    if len(sys.argv) < 4:
+        print("Usage: sentinel.py --kb-ingest <item_id> <content_type>")
+        sys.exit(1)
+    
+    item_id = sys.argv[2]
+    content_type = sys.argv[3]
+    
+    # Get content from environment variable
+    content = os.environ.get('KB_CONTENT', '')
+    
+    if not content:
+        print("Error: KB_CONTENT environment variable not set")
+        sys.exit(1)
+    
+    processor = KBIngestProcessor()
+    
+    try:
+        result = processor.process_kb_ingest(item_id, content, content_type)
+        print(json.dumps({
+            'status': 'success',
+            'item_id': item_id,
+            'title': result['title'],
+            'impact_score': result['impact_score']
+        }))
+    except Exception as e:
+        print(json.dumps({
+            'status': 'error',
+            'item_id': item_id,
+            'error': str(e)
+        }))
+        sys.exit(1)
+
+
+def main():
+    """Main entry point"""
+    # Check for KB ingest mode
+    if len(sys.argv) > 1 and sys.argv[1] == '--kb-ingest':
+        process_kb_ingest_command()
+        return
+    
+    engine = SentinelEngine()
+    
+    # Check if run once or continuous
+    if len(sys.argv) > 1 and sys.argv[1] == '--once':
+        result = engine.run_once()
+        print(json.dumps(result, indent=2))
+    else:
+        interval = int(os.environ.get('SENTINEL_INTERVAL_MINUTES', 30))
+        engine.run_continuous(interval)
+
+
+if __name__ == '__main__':
+    main()
