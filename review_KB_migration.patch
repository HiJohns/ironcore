--- /dev/null	2026-03-05 20:46:52.586000027 +0000
+++ scripts/migrate_v1.py	2026-03-08 21:40:08.980010000 +0000
@@ -0,0 +1,388 @@
+#!/usr/bin/env python3
+"""
+Knowledge Base Migration Script v1.0
+Migrates markdown files from ~/knowledge to ironcore.db
+"""
+
+import os
+import sys
+import sqlite3
+import re
+import hashlib
+import shutil
+from pathlib import Path
+from datetime import datetime
+from typing import Dict, List, Tuple, Optional
+
+# Configuration
+SOURCE_DIR = os.path.expanduser("~/knowledge")
+DB_PATH = os.path.join(os.path.dirname(os.path.dirname(__file__)), 'ironcore.db')
+STORAGE_DIR = os.path.join(os.path.dirname(os.path.dirname(__file__)), 'storage', 'assets')
+
+class MigrationError(Exception):
+    """Custom exception for migration errors"""
+    pass
+
+class KnowledgeMigrator:
+    """Handles migration of markdown files to SQLite database"""
+    
+    def __init__(self, source_dir: str, db_path: str, storage_dir: str):
+        self.source_dir = Path(source_dir)
+        self.db_path = db_path
+        self.storage_dir = Path(storage_dir)
+        self.conn = None
+        self.stats = {
+            'files_processed': 0,
+            'files_skipped': 0,
+            'images_migrated': 0,
+            'errors': []
+        }
+    
+    def init_storage(self):
+        """Initialize storage directory"""
+        self.storage_dir.mkdir(parents=True, exist_ok=True)
+        print(f"✓ Storage directory ready: {self.storage_dir}")
+    
+    def init_db(self):
+        """Initialize database connection and schema"""
+        self.conn = sqlite3.connect(self.db_path)
+        cursor = self.conn.cursor()
+        
+        # Create kb_items table
+        cursor.execute('''
+            CREATE TABLE IF NOT EXISTS kb_items (
+                id TEXT PRIMARY KEY,
+                title TEXT NOT NULL,
+                content TEXT NOT NULL,
+                tldr TEXT,
+                original_url TEXT,
+                impact_score REAL DEFAULT 0.0,
+                created_at TEXT NOT NULL,
+                updated_at TEXT NOT NULL
+            )
+        ''')
+        
+        # Create indexes
+        cursor.execute('''
+            CREATE INDEX IF NOT EXISTS idx_kb_items_created_at 
+            ON kb_items(created_at DESC)
+        ''')
+        
+        # Create tags table
+        cursor.execute('''
+            CREATE TABLE IF NOT EXISTS tags (
+                id INTEGER PRIMARY KEY AUTOINCREMENT,
+                name TEXT NOT NULL UNIQUE,
+                created_at TEXT DEFAULT CURRENT_TIMESTAMP
+            )
+        ''')
+        
+        # Create item_tags junction table
+        cursor.execute('''
+            CREATE TABLE IF NOT EXISTS item_tags (
+                item_id TEXT NOT NULL,
+                tag_id INTEGER NOT NULL,
+                PRIMARY KEY (item_id, tag_id),
+                FOREIGN KEY (item_id) REFERENCES kb_items(id) ON DELETE CASCADE,
+                FOREIGN KEY (tag_id) REFERENCES tags(id) ON DELETE CASCADE
+            )
+        ''')
+        
+        self.conn.commit()
+        print(f"✓ Database schema ready: {self.db_path}")
+    
+    def generate_slug(self, title: str) -> str:
+        """Generate URL-friendly slug from title"""
+        # Remove non-alphanumeric characters except spaces and dashes
+        slug = re.sub(r'[^\w\s-]', '', title.lower())
+        # Replace spaces with dashes
+        slug = re.sub(r'\s+', '-', slug.strip())
+        # Remove consecutive dashes
+        slug = re.sub(r'-+', '-', slug)
+        
+        if not slug:
+            # Fallback to hash
+            slug = hashlib.md5(title.encode()).hexdigest()[:8]
+        
+        return slug[:50]  # Limit length
+    
+    def parse_frontmatter(self, content: str) -> Tuple[Dict, str]:
+        """Parse YAML frontmatter from markdown content"""
+        frontmatter = {}
+        body = content
+        
+        # Check for frontmatter delimiters
+        if content.startswith('---'):
+            parts = content.split('---', 2)
+            if len(parts) >= 3:
+                fm_text = parts[1].strip()
+                body = parts[2].strip()
+                
+                # Simple YAML parsing for common fields
+                for line in fm_text.split('\n'):
+                    if ':' in line:
+                        key, value = line.split(':', 1)
+                        key = key.strip()
+                        value = value.strip().strip('"\'')
+                        frontmatter[key] = value
+        
+        return frontmatter, body
+    
+    def extract_tags_from_path(self, file_path: Path) -> List[str]:
+        """Extract tags from directory structure"""
+        # Get relative path from source directory
+        rel_path = file_path.relative_to(self.source_dir)
+        
+        # Extract directory names as tags
+        tags = []
+        for part in rel_path.parent.parts:
+            if part and part not in ['.', '..']:
+                # Clean and normalize
+                tag = part.lower().replace(' ', '-')
+                if tag:
+                    tags.append(tag)
+        
+        return tags
+    
+    def compute_md5(self, file_path: Path) -> str:
+        """Compute MD5 hash of a file"""
+        hash_md5 = hashlib.md5()
+        with open(file_path, "rb") as f:
+            for chunk in iter(lambda: f.read(4096), b""):
+                hash_md5.update(chunk)
+        return hash_md5.hexdigest()
+    
+    def migrate_image(self, image_path: Path) -> Optional[str]:
+        """Migrate an image to storage directory"""
+        try:
+            if not image_path.exists():
+                print(f"  ⚠ Image not found: {image_path}")
+                return None
+            
+            # Compute hash and new filename
+            file_hash = self.compute_md5(image_path)
+            ext = image_path.suffix.lower()
+            new_filename = f"{file_hash}{ext}"
+            dest_path = self.storage_dir / new_filename
+            
+            # Copy if not already exists
+            if not dest_path.exists():
+                shutil.copy2(image_path, dest_path)
+                self.stats['images_migrated'] += 1
+                print(f"  ✓ Migrated image: {image_path.name} -> {new_filename}")
+            
+            return f"/storage/assets/{new_filename}"
+        except Exception as e:
+            print(f"  ✗ Failed to migrate image {image_path}: {e}")
+            return None
+    
+    def process_images(self, content: str, file_dir: Path) -> str:
+        """Process and migrate images in markdown content"""
+        # Pattern for markdown images: ![alt](path)
+        image_pattern = r'!\[([^\]]*)\]\(([^)]+)\)'
+        
+        def replace_image(match):
+            alt_text = match.group(1)
+            img_path = match.group(2)
+            
+            # Skip external URLs
+            if img_path.startswith(('http://', 'https://', '//')):
+                return match.group(0)
+            
+            # Resolve relative path
+            if img_path.startswith('/'):
+                img_full_path = self.source_dir / img_path.lstrip('/')
+            else:
+                img_full_path = file_dir / img_path
+            
+            # Migrate image
+            new_url = self.migrate_image(img_full_path)
+            
+            if new_url:
+                return f'![{alt_text}]({new_url})'
+            else:
+                return match.group(0)
+        
+        return re.sub(image_pattern, replace_image, content)
+    
+    def create_or_get_tag(self, name: str) -> int:
+        """Create a tag or get existing one, return tag ID"""
+        cursor = self.conn.cursor()
+        
+        # Normalize tag name
+        name = name.lower().strip()
+        if not name:
+            raise MigrationError("Tag name cannot be empty")
+        
+        # Try to insert, ignore if exists
+        cursor.execute(
+            'INSERT OR IGNORE INTO tags (name) VALUES (?)',
+            (name,)
+        )
+        self.conn.commit()
+        
+        # Get the tag ID
+        cursor.execute('SELECT id FROM tags WHERE name = ?', (name,))
+        row = cursor.fetchone()
+        if row:
+            return row[0]
+        else:
+            raise MigrationError(f"Failed to create/get tag: {name}")
+    
+    def link_tags_to_item(self, item_id: str, tags: List[str]):
+        """Create relationships between item and tags"""
+        cursor = self.conn.cursor()
+        
+        for tag_name in tags:
+            try:
+                tag_id = self.create_or_get_tag(tag_name)
+                cursor.execute(
+                    'INSERT OR IGNORE INTO item_tags (item_id, tag_id) VALUES (?, ?)',
+                    (item_id, tag_id)
+                )
+            except Exception as e:
+                print(f"  ⚠ Failed to link tag '{tag_name}': {e}")
+        
+        self.conn.commit()
+    
+    def process_file(self, file_path: Path) -> bool:
+        """Process a single markdown file"""
+        try:
+            print(f"\nProcessing: {file_path}")
+            
+            # Read file
+            with open(file_path, 'r', encoding='utf-8') as f:
+                content = f.read()
+            
+            # Parse frontmatter
+            frontmatter, body = self.parse_frontmatter(content)
+            
+            # Extract title
+            title = frontmatter.get('title', file_path.stem)
+            
+            # Generate ID
+            item_id = self.generate_slug(title)
+            
+            # Check for duplicate
+            cursor = self.conn.cursor()
+            cursor.execute('SELECT id FROM kb_items WHERE id = ?', (item_id,))
+            if cursor.fetchone():
+                print(f"  ⚠ Skipping duplicate: {item_id}")
+                self.stats['files_skipped'] += 1
+                return False
+            
+            # Extract original URL
+            original_url = frontmatter.get('original_url', frontmatter.get('url', ''))
+            
+            # Process images
+            processed_body = self.process_images(body, file_path.parent)
+            
+            # Extract tags from path and frontmatter
+            path_tags = self.extract_tags_from_path(file_path)
+            fm_tags = frontmatter.get('tags', '')
+            if isinstance(fm_tags, str):
+                fm_tags = [t.strip() for t in fm_tags.split(',') if t.strip()]
+            elif not isinstance(fm_tags, list):
+                fm_tags = []
+            
+            all_tags = list(set(path_tags + fm_tags))
+            
+            # Generate TLDR (first 200 chars of body)
+            tldr = re.sub(r'[#*`]', '', processed_body[:300]).strip()
+            if len(tldr) > 200:
+                tldr = tldr[:197] + '...'
+            
+            # Current timestamp
+            now = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
+            
+            # Insert into database
+            cursor.execute('''
+                INSERT INTO kb_items (id, title, content, tldr, original_url, impact_score, created_at, updated_at)
+                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
+            ''', (item_id, title, processed_body, tldr, original_url, 0.0, now, now))
+            
+            # Link tags
+            if all_tags:
+                self.link_tags_to_item(item_id, all_tags)
+            
+            self.conn.commit()
+            self.stats['files_processed'] += 1
+            
+            print(f"  ✓ Migrated: {title}")
+            print(f"    ID: {item_id}")
+            print(f"    Tags: {', '.join(all_tags) if all_tags else 'None'}")
+            
+            return True
+            
+        except Exception as e:
+            error_msg = f"Failed to process {file_path}: {e}"
+            print(f"  ✗ {error_msg}")
+            self.stats['errors'].append(error_msg)
+            return False
+    
+    def find_markdown_files(self) -> List[Path]:
+        """Find all markdown files in source directory"""
+        files = []
+        
+        if not self.source_dir.exists():
+            raise MigrationError(f"Source directory not found: {self.source_dir}")
+        
+        for ext in ['*.md', '*.markdown']:
+            files.extend(self.source_dir.rglob(ext))
+        
+        return sorted(files)
+    
+    def run(self):
+        """Run the migration process"""
+        print("="*60)
+        print("Knowledge Base Migration Tool v1.0")
+        print("="*60)
+        print(f"Source: {self.source_dir}")
+        print(f"Database: {self.db_path}")
+        print(f"Storage: {self.storage_dir}")
+        print("="*60)
+        
+        try:
+            # Initialize
+            self.init_storage()
+            self.init_db()
+            
+            # Find files
+            files = self.find_markdown_files()
+            print(f"\nFound {len(files)} markdown files\n")
+            
+            # Process files
+            for file_path in files:
+                self.process_file(file_path)
+            
+            # Print summary
+            print("\n" + "="*60)
+            print("Migration Summary")
+            print("="*60)
+            print(f"Files processed: {self.stats['files_processed']}")
+            print(f"Files skipped (duplicates): {self.stats['files_skipped']}")
+            print(f"Images migrated: {self.stats['images_migrated']}")
+            print(f"Errors: {len(self.stats['errors'])}")
+            
+            if self.stats['errors']:
+                print("\nErrors encountered:")
+                for error in self.stats['errors']:
+                    print(f"  - {error}")
+            
+            print("="*60)
+            print("✓ Migration complete!")
+            
+        except Exception as e:
+            print(f"\n✗ Migration failed: {e}")
+            sys.exit(1)
+        finally:
+            if self.conn:
+                self.conn.close()
+
+def main():
+    """Main entry point"""
+    migrator = KnowledgeMigrator(SOURCE_DIR, DB_PATH, STORAGE_DIR)
+    migrator.run()
+
+if __name__ == '__main__':
+    main()
